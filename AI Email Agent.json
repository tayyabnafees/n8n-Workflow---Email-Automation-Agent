        "openRouterApi": {
          "id": "U6cyWtu1KLeZQZpy",
          "name": "OpenRouter account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const originalRow = $('Read Pending Rows').all()[i].json;\n\n  // Skip rows with no email address\n  if (!originalRow.Email || !originalRow.Email.trim()) continue;\n\n  let output;\n  try {\n    const raw = item.json.output || '';\n    const cleaned = raw.replace(/^```json\\n?/, '').replace(/```$/, '').trim();\n    output = JSON.parse(cleaned);\n  } catch (e) {\n    output = { subject: 'Follow-up', body: item.json.output || '' };\n  }\n\n  const now = new Date();\n  const sentDate = now.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' });\n  const sentTime = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });\n\n  results.push({\n    json: {\n      Name: originalRow.Name,\n      Email: originalRow.Email,\n      Company: originalRow.Company,\n      Purpose: originalRow.Purpose,\n      Subject: output.subject,\n      Body: output.body,\n      SentDate: sentDate,\n      SentTime: sentTime,\n    }\n  });\n}\n\nreturn results;\n"
      },
